  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/three": "0.185.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.7.0"
}
